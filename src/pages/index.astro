---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portalrr — Invite Management for Plex & Jellyfin">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-purple-900/20 via-transparent to-transparent"></div>
    <div class="max-w-6xl mx-auto px-6 py-32 text-center relative">
      <img src="/logo.png" alt="Portalrr" class="w-24 h-24 mx-auto mb-8" />
      <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-purple-300 to-purple-500 bg-clip-text text-transparent">
        Invite management<br />for media servers
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">
        A modern, self-hosted portal for managing invites, users, and onboarding for Plex and Jellyfin servers.
      </p>
      <div class="flex gap-4 justify-center">
        <a href="https://github.com/portalrr-app/portalrr#quick-start" target="_blank" class="bg-purple-600 hover:bg-purple-500 text-white px-8 py-3 rounded-lg text-lg font-medium transition-colors">
          Get Started
        </a>
        <a href="https://github.com/portalrr-app/portalrr" target="_blank" class="bg-gray-800 hover:bg-gray-700 text-white px-8 py-3 rounded-lg text-lg font-medium transition-colors border border-gray-700">
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="max-w-6xl mx-auto px-6 py-24">
    <h2 class="text-3xl font-bold text-center mb-4">Everything you need</h2>
    <p class="text-gray-400 text-center mb-16 max-w-xl mx-auto">
      A complete alternative to Wizarr and JFA-GO with a modern UI and powerful features.
    </p>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-gray-900/50 border border-gray-800/50 rounded-xl p-6">
        <div class="w-10 h-10 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Invite Links</h3>
        <p class="text-gray-400 text-sm">Create shareable invite links with usage limits, expiry dates, and per-invite library access control.</p>
      </div>

      <div class="bg-gray-900/50 border border-gray-800/50 rounded-xl p-6">
        <div class="w-10 h-10 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"></path></svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">User Management</h3>
        <p class="text-gray-400 text-sm">Track all users, manage access, set expiry dates, and handle bulk operations across servers.</p>
      </div>

      <div class="bg-gray-900/50 border border-gray-800/50 rounded-xl p-6">
        <div class="w-10 h-10 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path></svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">30+ Themes</h3>
        <p class="text-gray-400 text-sm">Customize every detail with over 30 built-in themes, custom colors, fonts, and full branding support.</p>
      </div>

      <div class="bg-gray-900/50 border border-gray-800/50 rounded-xl p-6">
        <div class="w-10 h-10 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Block-Based Onboarding</h3>
        <p class="text-gray-400 text-sm">Build custom onboarding pages with a drag-and-drop block editor. Show rules, app links, guides, and more.</p>
      </div>

      <div class="bg-gray-900/50 border border-gray-800/50 rounded-xl p-6">
        <div class="w-10 h-10 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"></path></svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Multi-Server</h3>
        <p class="text-gray-400 text-sm">Connect multiple Plex and Jellyfin servers. Assign users to specific servers with per-server library access.</p>
      </div>

      <div class="bg-gray-900/50 border border-gray-800/50 rounded-xl p-6">
        <div class="w-10 h-10 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Notifications</h3>
        <p class="text-gray-400 text-sm">Discord bots, Telegram bots, webhooks, and customizable email templates for every event.</p>
      </div>

      <div class="bg-gray-900/50 border border-gray-800/50 rounded-xl p-6">
        <div class="w-10 h-10 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Security</h3>
        <p class="text-gray-400 text-sm">Multi-admin support with two-factor authentication, session management, audit logging, and encrypted secrets.</p>
      </div>

      <div class="bg-gray-900/50 border border-gray-800/50 rounded-xl p-6">
        <div class="w-10 h-10 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Referrals</h3>
        <p class="text-gray-400 text-sm">Let existing users invite their friends with personal referral links. Set limits per user.</p>
      </div>

      <div class="bg-gray-900/50 border border-gray-800/50 rounded-xl p-6">
        <div class="w-10 h-10 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"></path></svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Backup & Restore</h3>
        <p class="text-gray-400 text-sm">Full database backup and restore with one click. Never lose your configuration or user data.</p>
      </div>
    </div>
  </section>

  <!-- Quick Start -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <h2 class="text-3xl font-bold text-center mb-4">Up and running in minutes</h2>
    <p class="text-gray-400 text-center mb-12 max-w-xl mx-auto">
      Deploy with Docker and start managing invites right away.
    </p>
    <div class="max-w-2xl mx-auto bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-800 bg-gray-900/50">
        <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
        <span class="text-xs text-gray-500 ml-2">docker-compose.yml</span>
      </div>
      <pre class="p-6 text-sm text-gray-300 overflow-x-auto"><code>services:
  portalrr:
    image: ghcr.io/portalrr-app/portalrr:latest
    ports:
      - "3939:3939"
    environment:
      - ENCRYPTION_KEY=your-secret-key
    volumes:
      - portalrr-data:/app/prisma/data

volumes:
  portalrr-data:</code></pre>
    </div>
    <p class="text-center mt-6 text-gray-500 text-sm">
      Then run <code class="bg-gray-800 px-2 py-1 rounded text-purple-300">docker compose up -d</code> and open <code class="bg-gray-800 px-2 py-1 rounded text-purple-300">http://localhost:3939</code>
    </p>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-24 text-center">
    <div class="bg-gradient-to-r from-purple-900/30 to-purple-800/10 border border-purple-800/30 rounded-2xl p-12">
      <h2 class="text-3xl font-bold mb-4">Ready to try Portalrr?</h2>
      <p class="text-gray-400 mb-8 max-w-lg mx-auto">
        Deploy in minutes. Free and open source, forever.
      </p>
      <a href="https://github.com/portalrr-app/portalrr" target="_blank" class="bg-purple-600 hover:bg-purple-500 text-white px-8 py-3 rounded-lg text-lg font-medium transition-colors inline-block">
        Get Started on GitHub
      </a>
    </div>
  </section>
</Layout>
