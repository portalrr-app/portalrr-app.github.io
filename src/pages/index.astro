---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portalrr — Invite Management for Plex & Jellyfin">

  <!-- Hero: Product-first, asymmetric -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 overflow-hidden">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-2xl animate-fade-up">
        <p class="text-[var(--color-accent)] text-sm font-medium tracking-wide uppercase mb-4" style="font-family: var(--font-display);">Open Source</p>
        <h1 class="text-[clamp(2rem,5vw,3.5rem)] leading-[1.1] font-bold tracking-tight mb-6" style="font-family: var(--font-display);">
          The invite portal your media server deserves
        </h1>
        <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed mb-8 max-w-lg">
          Manage invites, onboard users, and control access to your Plex and Jellyfin servers. A complete replacement for Wizarr and JFA-GO.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="#install" class="inline-flex items-center justify-center gap-2 bg-[var(--color-accent)] hover:brightness-110 active:brightness-90 text-white px-5 py-3 sm:py-2.5 rounded-md text-sm font-medium transition-all duration-200">
            Install with Docker
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="https://github.com/portalrr-app/portalrr" target="_blank" class="inline-flex items-center justify-center gap-2 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] active:text-[var(--color-text-primary)] border border-[var(--color-border)] hover:border-[var(--color-border-light)] px-5 py-3 sm:py-2.5 rounded-md text-sm font-medium transition-all duration-200">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            View source
          </a>
        </div>
      </div>
    </div>

    <!-- Hero screenshot -->
    <div class="max-w-[1200px] mx-auto px-6 mt-16 animate-fade-up delay-2">
      <div class="relative rounded-lg overflow-hidden border border-[var(--color-border)] screenshot-shadow">
        <img src="/screenshots/dashboard.png" alt="Portalrr dashboard" class="w-full" loading="eager" />
      </div>
    </div>
  </section>

  <!-- Social proof strip -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-surface-1)]">
    <div class="max-w-[1200px] mx-auto px-6 py-5 flex flex-wrap items-center justify-center gap-x-6 md:gap-x-12 gap-y-3 text-xs md:text-sm text-[var(--color-text-muted)]">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-[var(--color-accent)]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
        Plex & Jellyfin
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        30+ themes
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Multi-server
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Docker &amp; Unraid
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        MIT License
      </span>
    </div>
  </section>

  <!-- Features: varied layout, not a grid of cards -->
  <section id="features" class="py-24 md:py-32">
    <div class="max-w-[1200px] mx-auto px-6">
      <p class="text-[var(--color-accent)] text-sm font-medium tracking-wide uppercase mb-3" style="font-family: var(--font-display);">Features</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4" style="font-family: var(--font-display);">Built for media server admins</h2>
      <p class="text-[var(--color-text-secondary)] max-w-lg mb-20">Not another generic tool. Every feature exists because someone running a Plex or Jellyfin server needed it.</p>

      <!-- Feature 1: Invite Links — large, with screenshot -->
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center mb-24">
        <div>
          <span class="text-[var(--color-warm)] text-xs font-medium uppercase tracking-widest">Core</span>
          <h3 class="text-2xl font-bold mt-2 mb-4" style="font-family: var(--font-display);">Invite links that do the work for you</h3>
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-6">
            Generate links with usage limits, expiry dates, and per-invite library access. Share a link — the user registers, picks a server, and gets provisioned automatically.
          </p>
          <ul class="space-y-2.5 text-sm text-[var(--color-text-secondary)]">
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 mt-0.5 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Per-invite library and server selection
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 mt-0.5 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Usage limits and automatic expiry
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 mt-0.5 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              User referral system with personal invite links
            </li>
          </ul>
        </div>
        <div class="relative rounded-lg overflow-hidden border border-[var(--color-border)] screenshot-shadow">
          <img src="/screenshots/invite-page.png" alt="Invite page" class="w-full" loading="lazy" />
        </div>
      </div>

      <!-- Feature 2: Onboarding — reversed -->
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center mb-24">
        <div class="order-2 md:order-1 relative rounded-lg overflow-hidden border border-[var(--color-border)] screenshot-shadow">
          <img src="/screenshots/on-boarding.png" alt="Onboarding editor" class="w-full" loading="lazy" />
        </div>
        <div class="order-1 md:order-2">
          <span class="text-[var(--color-warm)] text-xs font-medium uppercase tracking-widest">Customization</span>
          <h3 class="text-2xl font-bold mt-2 mb-4" style="font-family: var(--font-display);">Onboarding that actually onboards</h3>
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-6">
            Build step-by-step onboarding flows with a drag-and-drop block editor. Show users what apps to download, your server rules, request links — whatever they need to get started.
          </p>
          <ul class="space-y-2.5 text-sm text-[var(--color-text-secondary)]">
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 mt-0.5 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Drag-and-drop block editor
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 mt-0.5 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              App download links, rules, guides, custom HTML
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="w-4 h-4 mt-0.5 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              30+ themes with custom colors and fonts
            </li>
          </ul>
        </div>
      </div>

      <!-- Feature 3: Appearance — full width -->
      <div class="mb-24">
        <div class="max-w-lg mb-8">
          <span class="text-[var(--color-warm)] text-xs font-medium uppercase tracking-widest">Branding</span>
          <h3 class="text-2xl font-bold mt-2 mb-4" style="font-family: var(--font-display);">Make it yours</h3>
          <p class="text-[var(--color-text-secondary)] leading-relaxed">
            Over 30 built-in themes, custom accent colors, display fonts, and full logo/branding support. Your invite portal, your identity.
          </p>
        </div>
        <div class="relative rounded-lg overflow-hidden border border-[var(--color-border)] screenshot-shadow">
          <img src="/screenshots/apperance.png" alt="Appearance settings" class="w-full" loading="lazy" />
        </div>
      </div>

      <!-- Remaining features: compact list, not cards -->
      <div class="grid md:grid-cols-2 gap-x-16 gap-y-10">
        <div class="flex gap-4">
          <div class="w-8 h-8 rounded-md bg-[var(--color-surface-2)] flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/></svg>
          </div>
          <div>
            <h4 class="font-semibold mb-1" style="font-family: var(--font-display);">Multi-server support</h4>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Connect multiple Plex and Jellyfin servers. Assign users to specific servers with per-server library access.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="w-8 h-8 rounded-md bg-[var(--color-surface-2)] flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          </div>
          <div>
            <h4 class="font-semibold mb-1" style="font-family: var(--font-display);">Discord, Telegram &amp; webhooks</h4>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Get notified when users register, invites are used, or accounts expire. Customizable email templates for every event.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="w-8 h-8 rounded-md bg-[var(--color-surface-2)] flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <h4 class="font-semibold mb-1" style="font-family: var(--font-display);">Multi-admin with 2FA</h4>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Multiple admin accounts with two-factor authentication, session management, and a full audit log.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="w-8 h-8 rounded-md bg-[var(--color-surface-2)] flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
          </div>
          <div>
            <h4 class="font-semibold mb-1" style="font-family: var(--font-display);">User lifecycle management</h4>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Track users across servers, set auto-expiry, bulk manage access, and let users self-serve through their own portal.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="w-8 h-8 rounded-md bg-[var(--color-surface-2)] flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
          </div>
          <div>
            <h4 class="font-semibold mb-1" style="font-family: var(--font-display);">Backup &amp; restore</h4>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">One-click database backup and restore. Never lose your configuration, users, or invite history.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="w-8 h-8 rounded-md bg-[var(--color-surface-2)] flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          </div>
          <div>
            <h4 class="font-semibold mb-1" style="font-family: var(--font-display);">Request queue</h4>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">Let people request an invite without a link. Review, approve, or deny requests from the admin panel.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Install -->
  <section id="install" class="py-24 md:py-32 border-t border-[var(--color-border)]">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">
        <div>
          <p class="text-[var(--color-accent)] text-sm font-medium tracking-wide uppercase mb-3" style="font-family: var(--font-display);">Install</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4" style="font-family: var(--font-display);">One file. One command.</h2>
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-8">
            Create a <code class="text-[var(--color-accent-light)] bg-[var(--color-surface-2)] px-1.5 py-0.5 rounded text-sm">docker-compose.yml</code>, run it, and open port 3939. A setup wizard walks you through the rest.
          </p>
          <div class="space-y-4 text-sm">
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-surface-2)] text-[var(--color-text-muted)] flex items-center justify-center text-xs shrink-0 mt-0.5">1</span>
              <p class="text-[var(--color-text-secondary)]">Create the compose file with the config shown here</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-surface-2)] text-[var(--color-text-muted)] flex items-center justify-center text-xs shrink-0 mt-0.5">2</span>
              <p class="text-[var(--color-text-secondary)]">Run <code class="text-[var(--color-accent-light)] bg-[var(--color-surface-2)] px-1.5 py-0.5 rounded">docker compose up -d</code></p>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-surface-2)] text-[var(--color-text-muted)] flex items-center justify-center text-xs shrink-0 mt-0.5">3</span>
              <p class="text-[var(--color-text-secondary)]">Open <code class="text-[var(--color-accent-light)] bg-[var(--color-surface-2)] px-1.5 py-0.5 rounded">localhost:3939</code> and follow the setup wizard</p>
            </div>
          </div>
          <p class="text-xs text-[var(--color-text-muted)] mt-8">Also available on Unraid Community Applications.</p>
        </div>

        <div class="bg-[var(--color-surface-1)] border border-[var(--color-border)] rounded-lg overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2.5 border-b border-[var(--color-border)] text-xs text-[var(--color-text-muted)]">
            <span>docker-compose.yml</span>
            <button onclick="navigator.clipboard.writeText(document.getElementById('compose-code').textContent)" class="hover:text-[var(--color-text-secondary)] transition-colors">Copy</button>
          </div>
          <pre class="p-4 md:p-5 text-xs md:text-sm leading-relaxed overflow-x-auto"><code id="compose-code" class="text-[var(--color-text-secondary)]"><span class="text-[var(--color-accent-light)]">services</span>:
  <span class="text-[var(--color-accent-light)]">portalrr</span>:
    <span class="text-[var(--color-text-muted)]">image</span>: ghcr.io/portalrr-app/portalrr:latest
    <span class="text-[var(--color-text-muted)]">ports</span>:
      - "<span class="text-[var(--color-warm)]">3939</span>:<span class="text-[var(--color-warm)]">3939</span>"
    <span class="text-[var(--color-text-muted)]">environment</span>:
      - ENCRYPTION_KEY=<span class="text-[var(--color-warm)]">your-secret-key</span>
    <span class="text-[var(--color-text-muted)]">volumes</span>:
      - portalrr-data:/app/prisma/data

<span class="text-[var(--color-accent-light)]">volumes</span>:
  <span class="text-[var(--color-text-muted)]">portalrr-data</span>:</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 border-t border-[var(--color-border)]">
    <div class="max-w-[1200px] mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-4xl font-bold tracking-tight mb-4" style="font-family: var(--font-display);">Stop gatekeeping with spreadsheets</h2>
      <p class="text-[var(--color-text-secondary)] max-w-md mx-auto mb-8">
        Your media server deserves a proper invite system. Set it up in 5 minutes.
      </p>
      <a href="https://github.com/portalrr-app/portalrr" target="_blank" class="inline-flex items-center gap-2 bg-[var(--color-accent)] hover:brightness-110 text-white px-6 py-3 rounded-md font-medium transition-all duration-200">
        Get started
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

</Layout>
