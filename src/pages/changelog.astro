---
import Layout from '../layouts/Layout.astro';

let releases: any[] = [];
try {
  const res = await fetch('https://api.github.com/repos/portalrr-app/portalrr/releases', {
    headers: { 'Accept': 'application/vnd.github+json' }
  });
  if (res.ok) releases = await res.json();
} catch {}
---

<Layout title="Changelog — Portalrr">
  <section class="max-w-[720px] mx-auto px-6 pt-32 pb-24">
    <p class="text-[var(--color-accent)] text-sm font-medium tracking-wide uppercase mb-3" style="font-family: var(--font-display);">Changelog</p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4" style="font-family: var(--font-display);">What's new</h1>
    <p class="text-[var(--color-text-secondary)] mb-16">All releases are published on <a href="https://github.com/portalrr-app/portalrr/releases" target="_blank" class="text-[var(--color-accent-light)] hover:underline">GitHub Releases</a>.</p>

    {releases.length === 0 && (
      <div class="text-center py-16">
        <p class="text-[var(--color-text-muted)]">No releases published yet.</p>
      </div>
    )}

    <div class="space-y-16">
      {releases.map((release: any, i: number) => (
        <article>
          <div class="flex items-baseline gap-4 mb-4">
            <a href={release.html_url} target="_blank" class="text-xl font-bold hover:text-[var(--color-accent-light)] transition-colors" style="font-family: var(--font-display);">
              {release.name || release.tag_name}
            </a>
            <time class="text-xs text-[var(--color-text-muted)]" datetime={release.published_at}>
              {new Date(release.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
            {i === 0 && <span class="text-xs bg-[var(--color-accent-dim)] text-[var(--color-accent-light)] px-2 py-0.5 rounded">Latest</span>}
          </div>
          <div class="text-sm text-[var(--color-text-secondary)] leading-relaxed whitespace-pre-line">{release.body || 'No release notes.'}</div>
          {i < releases.length - 1 && <div class="border-b border-[var(--color-border)] mt-16"></div>}
        </article>
      ))}
    </div>
  </section>
</Layout>
