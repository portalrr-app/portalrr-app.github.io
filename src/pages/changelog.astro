---
import Layout from '../layouts/Layout.astro';

const res = await fetch('https://api.github.com/repos/portalrr-app/portalrr/releases');
const releases = await res.json();
---

<Layout title="Changelog — Portalrr">
  <section class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-4xl font-bold mb-4">Changelog</h1>
    <p class="text-gray-400 mb-12">All notable changes to Portalrr.</p>

    {releases.length === 0 && (
      <p class="text-gray-500">No releases yet.</p>
    )}

    <div class="space-y-12">
      {releases.map((release: any) => (
        <article class="relative pl-8 border-l-2 border-gray-800">
          <div class="absolute -left-2 top-1 w-4 h-4 rounded-full bg-purple-600 border-4 border-gray-950"></div>
          <div class="flex items-center gap-3 mb-3">
            <h2 class="text-xl font-semibold">{release.name || release.tag_name}</h2>
            <span class="text-xs bg-gray-800 text-gray-400 px-2 py-1 rounded">{new Date(release.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
          <div class="prose prose-invert prose-sm max-w-none text-gray-300" set:html={release.body?.replace(/\n/g, '<br/>') || 'No release notes.'} />
        </article>
      ))}
    </div>
  </section>
</Layout>
